# ============================================================
# TUDEX NETWORKS - CONFIGURACIÓN DEL GATEWAY MESH
# ============================================================

# --- CONFIGURACIÓN DE BASE DE DATOS (MYSQL/MARIADB) ---
# Usado para sincronizar claves entre múltiples Gateways (HA)
# Si no se proveen, el sistema caerá en modo SQLite (Single Point of Failure)

DB_TYPE=mysql
DB_HOST=srv1659.hstgr.io
DB_PORT=3306
DB_NAME=u487445196_tudex_db
DB_USER=u487445196_tudex_db
DB_PASS=your_secure_password_here

# Local DB Credentials (for docker-compose.local.yml)
MYSQL_ROOT_PASSWORD=your_secure_root_password_here
MYSQL_USER=tudex
MYSQL_PASSWORD=your_secure_password_here

# --- CONFIGURACIÓN DE ACCESO AL CLUSTER ---
# Clave Maestra de Red (Generada con: headscale preauthkeys create)
# Se usa en los nodos para auto-unirse.
TS_AUTHKEY=your_secure_authkey_here
TS_LOGIN_SERVER=https://vpn.tudexnetworks.com

# --- NOTA ---
# Copia este archivo a un nuevo archivo llamado .env
# y ajusta los valores antes de desplegar en Dokploy.
