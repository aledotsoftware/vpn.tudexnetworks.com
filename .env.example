# ============================================================
# TUDEX NETWORKS - CONFIGURACIÓN DEL GATEWAY MESH
# ============================================================

# --- CONFIGURACIÓN DE BASE DE DATOS (GOOGLE FIREBASE) ---
# Usado para sincronizar claves entre múltiples Gateways (HA)
# Si no se proveen, el sistema caerá en modo SQLite (Single Point of Failure)

DB_TYPE=%%DB_TYPE%%
FIREBASE_PROJECT_ID=%%FIREBASE_PROJECT_ID%%
FIREBASE_DB_URL=%%FIREBASE_DB_URL%%
FIREBASE_API_KEY=%%FIREBASE_API_KEY%%

DB_HOST=%%DB_HOST%%
DB_USER=%%DB_USER%%
DB_NAME=%%DB_NAME%%
DB_PASS=%%DB_PASS%%

# --- IDENTIDAD DEL GATEWAY ---
HEADSCALE_PRIVATE_KEY=%%HEADSCALE_PRIVATE_KEY%%
HEADSCALE_NOISE_PRIVATE_KEY=%%HEADSCALE_NOISE_PRIVATE_KEY%%
ADMIN_PASSWORD=%%ADMIN_PASSWORD%%

# --- CONFIGURACIÓN DE ACCESO AL CLUSTER ---
# Clave Maestra de Red (Generada con: headscale preauthkeys create)
# Se usa en los nodos para auto-unirse.
TS_AUTHKEY=%%TS_AUTHKEY%%
TS_LOGIN_SERVER=%%TS_LOGIN_SERVER%%

# --- NOTA ---
# Copia este archivo a un nuevo archivo llamado .env
# y ajusta los valores antes de desplegar en Dokploy.
